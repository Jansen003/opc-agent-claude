# OPC Agents .gitignore

# 运行时状态（不提交）
scripts/state.json
# 知识库（独立仓库，不提交）
project-context.md
# Playwright MCP 日志（不提交）
.playwright-mcp/
# OpenCode 自动生成（不提交）
.opencode/.gitignore
.opencode/node_modules/
.opencode/package.json
.opencode/package-lock.json
# 归档的技能（不提交，太大）
skills-archive/

# 社区技能（运行时安装，不提交）
.opencode/skills/*/
# OPC 专属技能（要提交）
!.opencode/skills/daily-check/
!.opencode/skills/meeting-minutes/
!.opencode/skills/knowledge-search/
# 长任务产出（运行时产物，不提交）
.opencode/work/*
!.opencode/work/.gitkeep
