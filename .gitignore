# OPC Agents .gitignore（Claude Code 版）

# 运行时状态（不提交）
scripts/state.json
# 知识库（独立仓库，不提交）
project-context.md
# Playwright MCP 日志（不提交）
.playwright-mcp/
# OpenCode 运行时依赖（不提交，已无 node_modules）
.opencode/node_modules/
.opencode/package.json
.opencode/package-lock.json

# 社区技能（运行时安装，不提交）
.opencode/skills/*/
# OPC 专属技能（要提交）
!.opencode/skills/daily-check/
!.opencode/skills/meeting-minutes/
!.opencode/skills/knowledge-search/
# 长任务产出（运行时产物，不提交）
.opencode/work/*
!.opencode/work/.gitkeep

# 环境变量文件（含真实密钥，不提交）
.env
.env.local
.env.production
# 系统文件
*.log
*.swp
*~
.DS_Store
.reasonix/
